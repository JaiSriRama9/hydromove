// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: /users/{userId}
// Document ID: {userId}
// Fields:
//   - uid: string (required)
//   - name: string (required)
//   - age: number (optional)
//   - weight: number (optional)
//   - gender: string (optional, enum: male, female, other)
//   - dailyWaterGoal: number (optional)
//   - dailyStepGoal: number (optional)
//   - activityLevel: string (optional, enum: sedentary, moderate, active)
//   - lockMode: string (optional, enum: soft, hard)
//   - homeMode: boolean (optional)
//   - reminderInterval: number (optional)
//   - createdAt: string (optional, format: date-time)
//
// Collection: /users/{userId}/hydration/{logId}
// Document ID: {logId}
// Fields:
//   - uid: string (required)
//   - amount: number (required)
//   - timestamp: string (required, format: date-time)
//
// Collection: /users/{userId}/activity/{logId}
// Document ID: {logId}
// Fields:
//   - uid: string (required)
//   - steps: number (required)
//   - calories: number (optional)
//   - timestamp: string (required, format: date-time)
//
// Collection: /users/{userId}/meditation/{sessionId}
// Document ID: {sessionId}
// Fields:
//   - uid: string (required)
//   - duration: number (required)
//   - type: string (optional)
//   - timestamp: string (required, format: date-time)
//
// Collection: /users/{userId}/reminders/{reminderId}
// Document ID: {reminderId}
// Fields:
//   - uid: string (required)
//   - title: string (required)
//   - type: string (required, enum: water, walking, bill, habit, custom)
//   - dueDate: string (optional, format: date-time)
//   - isPaid: boolean (optional)
//   - completedDates: list (optional, for habits)
//   - recurrence: string (optional, enum: none, daily, weekly, monthly, yearly, weekday, monthly_specific)
//   - daysOfMonth: list (optional, list of numbers 1-31)
//   - scheduledTime: string (optional, HH:mm)
//   - voiceNoteUrl: string (optional)
//   - customAlertToneUrl: string (optional)
//   - amount: number (optional)
//   - createdAt: string (optional, format: date-time)
//
// Collection: /users/{userId}/exercises/{logId}
// Document ID: {logId}
// Fields:
//   - uid: string (required)
//   - exerciseName: string (required)
//   - duration: number (required)
//   - intensity: string (optional, enum: low, moderate, high)
//   - caloriesBurned: number (optional)
//   - timestamp: string (required, format: date-time)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name']) &&
             data.uid is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             (!('onboardingCompleted' in data) || data.onboardingCompleted is bool) &&
             (!('dailyWaterGoal' in data) || data.dailyWaterGoal is number && data.dailyWaterGoal > 0) &&
             (!('dailyStepGoal' in data) || data.dailyStepGoal is number && data.dailyStepGoal > 0) &&
             (!('lockMode' in data) || data.lockMode in ['soft', 'hard']) &&
             (!('homeMode' in data) || data.homeMode is bool) &&
             (!('reminderInterval' in data) || data.reminderInterval is number && data.reminderInterval > 0);
    }

    function isValidHydrationLog(data) {
      return data.keys().hasAll(['uid', 'amount', 'timestamp']) &&
             data.uid == request.auth.uid &&
             data.amount is number && data.amount > 0 &&
             data.timestamp is string;
    }

    function isValidActivityLog(data) {
      return data.keys().hasAll(['uid', 'steps', 'timestamp']) &&
             data.uid == request.auth.uid &&
             data.steps is number && data.steps >= 0 &&
             data.timestamp is string;
    }

    function isValidMeditationSession(data) {
      return data.keys().hasAll(['uid', 'duration', 'timestamp']) &&
             data.uid == request.auth.uid &&
             data.duration is number && data.duration > 0 &&
             data.timestamp is string;
    }

    function isValidReminder(data) {
      return data.keys().hasAll(['uid', 'title', 'type']) &&
             data.keys().hasOnly(['uid', 'title', 'type', 'icon', 'dueDate', 'isPaid', 'completedDates', 'recurring', 'recurrence', 'daysOfMonth', 'scheduledTime', 'voiceNoteUrl', 'customAlertToneUrl', 'amount', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.type is string &&
             (!('isPaid' in data) || data.isPaid is bool) &&
             (!('completedDates' in data) || data.completedDates == null || data.completedDates is list) &&
             (!('recurring' in data) || data.recurring is bool) &&
             (!('recurrence' in data) || data.recurrence in ['none', 'daily', 'weekly', 'monthly', 'yearly', 'weekday', 'monthly_specific']) &&
             (!('daysOfMonth' in data) || data.daysOfMonth == null || (data.daysOfMonth is list)) &&
             (!('icon' in data) || data.icon is string) &&
             (!('dueDate' in data) || data.dueDate == null || data.dueDate is string) &&
             (!('scheduledTime' in data) || data.scheduledTime == null || data.scheduledTime is string) &&
             (!('amount' in data) || data.amount == null || data.amount is number) &&
             (!('voiceNoteUrl' in data) || data.voiceNoteUrl == null || (data.voiceNoteUrl is string && data.voiceNoteUrl.size() < 1048576)) &&
             (!('customAlertToneUrl' in data) || data.customAlertToneUrl == null || (data.customAlertToneUrl is string && data.customAlertToneUrl.size() < 1048576)) &&
             (!('createdAt' in data) || data.createdAt is string);
    }

    function isValidExerciseLog(data) {
      return data.keys().hasAll(['uid', 'exerciseName', 'duration', 'timestamp']) &&
             data.uid == request.auth.uid &&
             data.exerciseName is string && data.exerciseName.size() > 0 && data.exerciseName.size() < 100 &&
             data.duration is number && data.duration > 0 &&
             data.timestamp is string;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if isOwner(userId);

      match /hydration/{logId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidHydrationLog(request.resource.data);
        allow update: if isOwner(userId) && isValidHydrationLog(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /activity/{logId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidActivityLog(request.resource.data);
        allow update: if isOwner(userId) && isValidActivityLog(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /meditation/{sessionId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidMeditationSession(request.resource.data);
        allow update: if isOwner(userId) && isValidMeditationSession(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /reminders/{reminderId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidReminder(request.resource.data);
        allow update: if isOwner(userId) && isValidReminder(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /exercises/{logId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidExerciseLog(request.resource.data);
        allow update: if isOwner(userId) && isValidExerciseLog(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
